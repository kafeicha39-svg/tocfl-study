rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/progress/{progressDoc} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      function isValidProgress() {
        return progressDoc == 'current'
          && request.resource.data.keys().hasOnly(['completed', 'updatedAt', 'schemaVersion'])
          && request.resource.data.schemaVersion == 1
          && request.resource.data.completed is map
          && request.resource.data.completed.size() <= 500
          && request.resource.data.updatedAt is timestamp;
      }

      allow read: if isOwner() && progressDoc == 'current';
      allow create, update: if isOwner() && isValidProgress();
      allow delete: if false;
    }

    match /users/{userId}/study/{studyDoc} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      function isValidStudy() {
        return studyDoc == 'current'
          && request.resource.data.keys().hasOnly(['weakItems', 'updatedAt', 'schemaVersion'])
          && request.resource.data.schemaVersion == 1
          && request.resource.data.weakItems is map
          && request.resource.data.weakItems.size() <= 500
          && request.resource.data.updatedAt is timestamp;
      }

      allow read: if isOwner() && studyDoc == 'current';
      allow create, update: if isOwner() && isValidStudy();
      allow delete: if false;
    }
  }
}
